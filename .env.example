# Node Environment
# Options: development, production, test
NODE_ENV=development

# Application Configuration
VITE_APP_ID=your_app_id_here
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_random_string

# Database Configuration
# Format: mysql://username:password@host:port/database
DATABASE_URL=mysql://username:password@localhost:3306/influxity_ai

# OAuth Configuration
OAUTH_SERVER_URL=https://oauth.manus.im
OWNER_OPEN_ID=your_owner_open_id

# AI/LLM Configuration
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your_openai_api_key_here

# Stripe Configuration
# Test keys (use sk_test_ for development)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Production Note:
# - Use strong, unique secrets for JWT_SECRET
# - Use sk_live_ prefix for production Stripe keys
# - Never commit actual secrets to version control
# - Use environment-specific configuration management
